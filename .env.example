# Environment Configuration for Data Cleaning OpenEnv
# Copy this to .env and fill in your actual values

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://admin:password@postgres:5432/data_cleaning
POSTGRES_DB=data_cleaning
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# ============================================================================
# REDIS (Celery)
# ============================================================================
REDIS_URL=redis://redis:6379/0

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# API endpoint for LLM (defaults to localhost:7860 for testing)
# ============================================================================
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
HF_TOKEN=your_api_key_here
ENV_URL=http://localhost:7860

# ============================================================================
# USAGE NOTES
# ============================================================================
# 
# For OpenAI API:
#   API_BASE_URL=https://api.openai.com/v1
#   MODEL_NAME=gpt-4o-mini  (cheapest, ~$0.15/1M tokens)
#   HF_TOKEN=sk-...         (your OpenAI API key)
#
# For HuggingFace Inference:
#   API_BASE_URL=https://api-inference.huggingface.co/v1
#   MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
#   HF_TOKEN=hf_...         (your HF token)
#
# For local testing without LLM:
#   Use test_inference_format.py (rule-based actions)
